# ══════════════════════════════════════════════════════════
#  SK TECHVERSE — Frontend Environment Variables
#  Copy this file to .env and fill in your own real values.
#  NEVER commit the actual .env file to GitHub.
# ══════════════════════════════════════════════════════════

# Backend API URL — local dev:
REACT_APP_API_URL=http://localhost:5000/api
# Single-project Vercel deployment (frontend + backend together, same domain):
# REACT_APP_API_URL=/api
# Split deployment (backend hosted separately, e.g. Render/Railway):
# REACT_APP_API_URL=https://your-backend.onrender.com/api

# WhatsApp business number (with country code, no spaces)
REACT_APP_WHATSAPP=91XXXXXXXXXX

# Google Maps API key (for Contact page map)
REACT_APP_GOOGLE_MAPS_KEY=your-google-maps-api-key

# Site metadata
REACT_APP_SITE_NAME=SK TECHVERSE
REACT_APP_SITE_URL=https://your-frontend.vercel.app

HOST=localhost
PORT=3000
