# ══════════════════════════════════════════════════════════
#  SK TECHVERSE — Backend Environment Variables
#  Copy this file to .env and fill in your own real values.
#  NEVER commit the actual .env file to GitHub.
# ══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend URL (CORS) ───────────────────────────────────
# On Vercel single-project deployment, frontend and backend share the same
# domain, so this mostly matters for local dev / cross-domain setups.
CLIENT_URL=http://localhost:3000

# ── MongoDB ───────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/sk-techverse
# Atlas (production) — get this from MongoDB Atlas > Connect > Drivers:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sk-techverse

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRE=7d

# ── Email (Gmail App Password — generate at myaccount.google.com/apppasswords) ──
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password
ADMIN_EMAIL=your-email@gmail.com

# ── WhatsApp ──────────────────────────────────────────────
WHATSAPP_NUMBER=91XXXXXXXXXX

# ── Cloudinary (REQUIRED — project screenshot uploads) ────
# Uploaded images are streamed straight to Cloudinary instead of local
# disk, because Vercel's serverless filesystem is ephemeral. Get these
# free at cloudinary.com > Dashboard.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Production frontend URL (set this after deploying frontend on Vercel) ──
FRONTEND_URL=https://your-frontend.vercel.app
